{
  "name": "lynx-keymap",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "2.6.0",
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Keymaps","Other"],
  "keywords": [
    "AI Orchestrator",
    "productivity",
    "antigravity",
    "claude code",
    "keybindings",
    "shortcuts",
    "opencode",
    "keyboard",
    "windows",
    "keymap",
    "linux",
    "macos",
    "codex",
    "2026",
    "ai"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/Lynx-Keymap-Pro#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bastndev/Lynx-Keymap-Pro"
  },
  "bugs": {
    "url": "https://github.com/bastndev/Lynx-Keymap-Pro/issues/new"
  },
  "author": {
    "name": "Gohit Bastian", 
    "email": "bastndev@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/gohit.xyz"
  },
  
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  
  "contributes": {
"keybindings": [
        {
        "key"    : "ctrl+z",
        "mac"    : "cmd+z",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : { "text": "\u0000" },
        "when"   : "terminalFocus"
      },{
        "key"    : "ctrl+alt+backspace",
        "mac"    : "cmd+alt+backspace",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : {"text": "\u0001\u000b"},
        "when"   : "terminalFocus"
      },{
        "key"    : "ctrl+p",
        "mac"    : "cmd+p",
        "command": "-workbench.action.quickOpen"
      },{
        "key"    : "ctrl+,",
        "mac"    : "cmd+,",
        "command": "-workbench.action.openAntigravitySettings"
      },{
        "key"    : "ctrl+enter",
        "mac"    : "cmd+return",
        "command": "-github.copilot.generate"
      },{
        "key"    : "ctrl+e",
        "mac"    : "ctrl+e",
        "command": "-workbench.debug.action.toggleRepl"
      },








      {
        "key"    : "ctrl+e",
        "mac"    : "ctrl+e",
        "command": "lynx-keymap.openGitlabPanel"
      },{
        "key"    : "ctrl+q",
        "mac"    : "ctrl+q",
        "command": "workbench.debug.action.toggleRepl"
      },{
        "key"    : "ctrl+3",
        "mac"    : "cmd+3",
        "command": "lynx-keymap.openMySkillsPanel"
      },
      {
        "key"    : "alt+0",
        "mac"    : "alt+0",
        "command": "lynx-keymap.toggleLayout"
      },








      {
        "key"    : "alt+capslock",
        "mac"    : "alt+capslock",
        "command": "lynx-keymap.toggleTerminalLeftAndRight"
      },{
        "key"    : "ctrl+tab",
        "mac"    : "cmd+tab",
        "command": "lynx-keymap.openAndCloseAIChatAndTerminal"
      },{
        "key"    : "ctrl+shift+tab",
        "mac"    : "cmd+shift+tab",
        "command": "workbench.action.toggleSidebarVisibility"
      },






      {
        "key"    : "alt+shift+audiovolumedown",
        "mac"    : "alt+shift+audiovolumedown",
        "command": "workbench.action.zoomOut",
        "when"   : "editorTextFocus || !inputFocus"
      },{
        "key"    : "alt+shift+audiovolumeup",
        "mac"    : "alt+shift+audiovolumeup",
        "command": "workbench.action.zoomIn",
        "when"   : "editorTextFocus || !inputFocus"
      },
      
      
      {
        "key"    : "ctrl+backspace",
        "mac"    : "cmd+backspace",
        "command": "deleteWordLeft",
        "when"   : "editorTextFocus"
      },{
        "key"    : "ctrl+delete",
        "mac"    : "cmd+delete",
        "command": "workbench.action.closeFolder"
      },
      
      
      {
        "key"    : "alt+shift+down",
        "mac"    : "alt+shift+down",
        "command": "editor.action.copyLinesDownAction"
      },{
        "key"    : "alt+shift+up",
        "mac"    : "alt+shift+up",
        "command": "editor.action.copyLinesUpAction"
      },{
        "key"    : "alt+enter",
        "mac"    : "alt+return",
        "command": "inlineChat.close",
        "when"   : "inlineChatFocused"
      },      {
        "key"    : "ctrl+down",
        "mac"    : "cmd+down",
        "command": "editor.action.insertCursorBelow"
      },{
        "key"    : "ctrl+up",
        "mac"    : "cmd+up",
        "command": "editor.action.insertCursorAbove"
      },










      {
        "key"    : "end",
        "mac"    : "end",
        "command": "workbench.action.quit"
      },

      {
        "key"    : "alt+l",
        "mac"    : "alt+l",
        "command": "git.viewChanges",
        "when"   : "lynx.keymap != 'compact'"
      },{
        "key"    : "pageup",
        "mac"    : "pageup",
        "command": "git.viewChanges",
        "when"   : "lynx.keymap == 'compact'"
      },

      {
        "key"    : "alt+m",
        "mac"    : "alt+m",
        "command": "markdown.showPreviewToSide",
        "when"   : "lynx.keymap != 'compact'"
      },{
        "key"    : "pagedown",
        "mac"    : "pagedown",
        "command": "markdown.showPreviewToSide",
        "when"   : "lynx.keymap == 'compact'"
      },
      
      
      {
        "key"    : "alt+i",
        "mac"    : "alt+i",
        "command": "workbench.action.debug.stop",
        "when"   : "lynx.keymap != 'compact'"
      },{
        "key"    : "ctrl+insert",
        "mac"    : "cmd+insert",
        "command": "workbench.action.debug.stop",
        "when"   : "lynx.keymap == 'compact'"
      },

      {
        "key"    : "alt+o",
        "mac"    : "alt+o",
        "command": "workbench.action.debug.restart",
        "when"   : "lynx.keymap != 'compact'"
      },{
        "key"    : "alt+insert",
        "mac"    : "alt+insert",
        "command": "workbench.action.debug.restart",
        "when"   : "lynx.keymap == 'compact'"
      },

      {
        "key"    : "alt+p",
        "mac"    : "alt+p",
        "command": "lynx-keymap.smartDebugStart",
        "when"   : "lynx.keymap != 'compact'"
      },{
        "key"    : "insert",
        "mac"    : "insert",
        "command": "lynx-keymap.smartDebugStart",
        "when"   : "lynx.keymap == 'compact'"
      },{
        "key"    : "f5",
        "mac"    : "f5",
        "command": "lynx-keymap.smartDebugStart"
      },











      
      











      {
        "key"    : "shift+alt+t",
        "mac"    : "shift+alt+t",
        "command": "workbench.action.selectTheme"
      },{
        "key"    : "shift+alt+r",
        "mac"    : "shift+alt+r",
        "command": "workbench.action.reloadWindow"
      },{
        "key"    : "shift+alt+e",
        "mac"    : "shift+alt+e",
        "command": "workbench.action.quickOpen"
      },
      {
        "key"    : "alt+e",
        "mac"    : "alt+e",
        "command": "workbench.action.togglePanel"
      },{
        "key"    : "shift+alt+w",
        "mac"    : "shift+alt+w",
        "command": "workbench.action.gotoLine"
      },{
        "key"    : "shift+alt+q",
        "mac"    : "shift+alt+q",
        "command": "expandLineSelection"
      },










      
      {
        "key"    : "shift+alt+d",
        "mac"    : "shift+alt+d",
        "command": "lynx.toggleSuggestionAI"
      },{
        "key"    : "shift+alt+s",
        "mac"    : "shift+alt+s",
        "command": "lynx-keymap.showAIHistory"
      },{
        "key"    : "shift+alt+a",
        "mac"    : "shift+alt+a",
        "command": "lynx-keymap.toggleAgentMode"
      },
      
      
      {
        "key"    : "alt+d",
        "mac"    : "alt+d",
        "command": "lynx-keymap.selectCode"
      },{
        "key"    : "alt+s",
        "mac"    : "alt+s",
        "command": "lynx-keymap.selectModels"
      },{
        "key"    : "alt+a",
        "mac"    : "alt+a",
        "command": "lynx-keymap.createNewAISession"
      },
      
      
      
      {
        "key"    : "ctrl+[Backquote]",
        "mac"    : "cmd+[Backquote]",
        "command": "workbench.action.toggleMaximizedPanel"
      },
      {
        "key"    : "shift+escape",
        "mac"    : "shift+escape",
        "command": "workbench.action.toggleMaximizedAuxiliaryBar"
      },
      
      
      
      {
        "key"    : "ctrl+alt+[Backquote]",
        "mac"    : "cmd+alt+[Backquote]",
        "command": "workbench.action.terminal.kill"
      },{
        "key"    : "ctrl+shift+[Backquote]",
        "mac"    : "cmd+shift+[Backquote]",
        "command": "lynx-keymap.smartNewTerminal"
      },
      
      {
        "key"    : "ctrl+capslock",
        "mac"    : "ctrl+capslock",
        "command": "lynx-keymap.toggleTerminalBottom"
      },{
        "key"    : "alt+w",
        "mac"    : "alt+w",
        "command": "workbench.action.quickOpenTerm"
      },{
        "key"    : "alt+q",
        "mac"    : "alt+q",
        "command": "workbench.action.focusFirstEditorGroup"
      },
      








      
      
      
      
      
      
      
      {
        "key"    : "shift+alt+f",
        "mac"    : "shift+alt+f",
        "command": "editor.action.organizeImports"
      },{
        "key"    : "ctrl+alt+f",
        "mac"    : "cmd+alt+f",
        "command": "editor.action.formatSelection.multiple"
      },{
        "key"    : "alt+f",
        "mac"    : "alt+f",
        "command": "editor.action.formatDocument"
      },
      
      
      
      
      
      
      {
        "key"    : "ctrl+j",
        "mac"    : "cmd+j",
        "command": "workbench.action.openSettings"
      },
      {
        "key"    : "ctrl+,", 
        "mac"    : "cmd+,",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : {"text": "\u001b[C"},
        "when"   : "terminalFocus"
      },
      {
        "key"    : "alt+j",
        "mac"    : "alt+j",
        "command": "workbench.action.openSettingsJson"
      },
      
      
      
      
      
      
      {
        "key"    : "alt+/",
        "mac"    : "alt+/",
        "command": "editor.action.blockComment"
      },{
        "key"    : "ctrl+/",
        "mac"    : "cmd+/",
        "command": "editor.action.commentLine"
      },
      
      
      
      
      
      
      {
        "key"    : "ctrl+alt+enter",
        "mac"    : "cmd+alt+return",
        "command": "git.push",
        "when"   : "scmProvider == git"
      },{
        "key"    : "ctrl+shift+alt+backspace",
        "mac"    : "cmd+shift+alt+backspace",
        "command": "lynx-keymap.gitResetHardHead"
      },{
        "key"    : "alt+enter",
        "mac"    : "alt+return",
        "command": "git.commit",
        "when"   : "scmProvider == git"
      },
      
      {
        "key"    : "alt+3",
        "mac"    : "alt+3",
        "command": "git.unstageAll",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+2",
        "mac"    : "alt+2",
        "command": "lynx-keymap.generateAICommit",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+1",
        "mac"    : "alt+1",
        "command": "git.stageAll",
        "when"   : "scmProvider == git"
      },


      {
        "key"    : "alt+c",
        "mac"    : "alt+c",
        "command": "explorer.newFolder"
      },{
        "key"    : "alt+x",
        "mac"    : "alt+x",
        "command": "explorer.newFile"
      },
      {
        "key"    : "alt+z",
        "mac"    : "alt+z",
        "command": "lynx-keymap.toggleWordWrap"
      },
      
      {
        "key"    : "ctrl+4",
        "mac"    : "cmd+4",
        "command": "workbench.view.extensions"
