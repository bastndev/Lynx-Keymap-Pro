{
  "name": "lynx-keymap",
  "displayName": "Lynx Keymap Pro",
  "description": "Available now: VSCode • Cursor • Windsurf • Trae.ai • Kiro & (Firebase Studio)... 雨",
  "version": "2.2.4",
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
		"vscode": "^1.75.0"
  },
  "categories": ["Keymaps","Other"],
  "keywords": [
    "AI Orchestrator",
    "75% keyboard",
    "productivity",
    "antigravity",
    "keybindings",
    "shortcuts",
    "windows",
    "keymap",
    "linux",
    "macos",
    "2026",
    "ai"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/Lynx-Keymap-75#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bastndev/Lynx-Keymap-75"
  },
  "bugs": {
    "url": "https://github.com/bastndev/Lynx-Keymap-75/issues"
  },
  "author": {
    "name": "Gohit Bastian", 
    "email": "bastndev@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/gohit.xyz"
  },
  
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  
  "contributes": {
"keybindings": [
        {
        "key"    : "ctrl+z",
        "mac"    : "cmd+z",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : { "text": "\u0000" },
        "when"   : "terminalFocus"
      },{
        "key"    : "ctrl+p",
        "mac"    : "cmd+p",
        "command": "-workbench.action.quickOpen"
      },{
        "key"    : "alt+,", 
        "mac"    : "alt+,",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : {"text": "\u001b[C"},
        "when"   : "terminalFocus && !terminalSuggestWidgetVisible"
      },{
        "key"    : "ctrl+alt+backspace",
        "mac"    : "cmd+alt+backspace",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : {"text": "\u0001\u000b"},
        "when"   : "terminalFocus"
      },{
        "key"    : "ctrl+enter",
        "mac"    : "cmd+return",
        "command": "-github.copilot.generate"
      },












      {
        "key"    : "alt+shift+audiovolumedown",
        "mac"    : "alt+shift+audiovolumedown",
        "command": "workbench.action.zoomOut",
        "when"   : "editorTextFocus || !inputFocus"
      },{
        "key"    : "alt+shift+audiovolumeup",
        "mac"    : "alt+shift+audiovolumeup",
        "command": "workbench.action.zoomIn",
        "when"   : "editorTextFocus || !inputFocus"
      },
      
      
      {
        "key"    : "ctrl+backspace",
        "mac"    : "cmd+backspace",
        "command": "deleteWordLeft",
        "when"   : "editorTextFocus"
      },{
        "key"    : "ctrl+delete",
        "mac"    : "cmd+delete",
        "command": "workbench.action.closeFolder"
      },
      
      
      {
        "key"    : "alt+shift+down",
        "mac"    : "alt+shift+down",
        "command": "editor.action.copyLinesDownAction"
      },{
        "key"    : "alt+shift+up",
        "mac"    : "alt+shift+up",
        "command": "editor.action.copyLinesUpAction"
      },{
        "key"    : "alt+enter",
        "mac"    : "alt+return",
        "command": "inlineChat.close",
        "when"   : "inlineChatFocused"
      },      {
        "key"    : "ctrl+down",
        "mac"    : "cmd+down",
        "command": "editor.action.insertCursorBelow"
      },{
        "key"    : "ctrl+up",
        "mac"    : "cmd+up",
        "command": "editor.action.insertCursorAbove"
      },









      {
        "key"    : "pagedown",
        "mac"    : "pagedown",
        "command": "workbench.action.togglePanel"
      },{
        "key"    : "pageup",
        "mac"    : "pageup",
        "command": "markdown.showPreviewToSide"
      },{
        "key"    : "end",
        "mac"    : "end",
        "command": "git.viewChanges"
      },
      
      
      {
        "key"    : "ctrl+insert",
        "mac"    : "cmd+insert",
        "command": "workbench.action.debug.stop"
      },{
        "key"    : "alt+insert",
        "mac"    : "alt+insert",
        "command": "workbench.action.debug.restart"
      },{
        "key"    : "insert",
        "mac"    : "insert",
        "command": "workbench.action.debug.start"
      },










      {
        "key"    : "alt+/",
        "mac"    : "alt+/",
        "command": "editor.action.blockComment"
      },{
        "key"    : "ctrl+/",
        "mac"    : "cmd+/",
        "command": "editor.action.commentLine"
      },
      
      
      {
        "key"    : "shift+alt+f",
        "mac"    : "shift+alt+f",
        "command": "editor.action.organizeImports"
      },{
        "key"    : "ctrl+alt+f",
        "mac"    : "cmd+alt+f",
        "command": "editor.action.formatSelection.multiple"
      },{
        "key"    : "alt+f",
        "mac"    : "alt+f",
        "command": "editor.action.formatDocument"
      },
      
      
      {
        "key"    : "ctrl+j",
        "mac"    : "cmd+j",
        "command": "workbench.action.openSettings"
      },{
        "key"    : "ctrl+,",
        "mac"    : "cmd+,",
        "command": ""
      },{
        "key"    : "alt+j",
        "mac"    : "alt+j",
        "command": "workbench.action.openSettingsJson"
      },










      {
        "key"    : "shift+alt+t",
        "mac"    : "shift+alt+t",
        "command": "workbench.action.selectTheme"
      },{
        "key"    : "shift+alt+r",
        "mac"    : "shift+alt+r",
        "command": "workbench.action.reloadWindow"
      },{
        "key"    : "shift+alt+e",
        "mac"    : "shift+alt+e",
        "command": "workbench.action.quickOpen"
      },{
        "key"    : "shift+alt+w",
        "mac"    : "shift+alt+w",
        "command": "workbench.action.gotoLine"
      },{
        "key"    : "shift+alt+q",
        "mac"    : "shift+alt+q",
        "command": "expandLineSelection"
      },










      
      {
        "key"    : "shift+alt+d",
        "mac"    : "shift+alt+d",
        "command": "lynx.toggleSuggestionAI"
      },{
        "key"    : "shift+alt+s",
        "mac"    : "shift+alt+s",
        "command": "lynx-keymap.showAIHistory"
      },{
        "key"    : "shift+alt+a",
        "mac"    : "shift+alt+a",
        "command": "lynx-keymap.toggleAgentMode"
      },
      
      
      {
        "key"    : "alt+d",
        "mac"    : "alt+d",
        "command": "lynx-keymap.selectCode"
      },{
        "key"    : "alt+s",
        "mac"    : "alt+s",
        "command": "lynx-keymap.selectModels"
      },{
        "key"    : "alt+a",
        "mac"    : "alt+a",
        "command": "lynx-keymap.createNewAISession"
      },
      
      
      
      {
        "key"    : "ctrl+escape",
        "mac"    : "cmd+escape",
        "command": "workbench.action.toggleMaximizedPanel"
      },
      {
        "key"    : "shift+escape",
        "mac"    : "shift+escape",
        "command": "workbench.action.toggleMaximizedAuxiliaryBar"
      },
      
      
      
      {
        "key"    : "ctrl+alt+[Backquote]",
        "mac"    : "cmd+alt+[Backquote]",
        "command": "workbench.action.terminal.kill"
      },{
        "key"    : "ctrl+[Backquote]",
        "mac"    : "cmd+[Backquote]",
        "command": "workbench.action.terminal.new"
      },
      
      {
        "key"    : "alt+e",
        "mac"    : "alt+e",
        "command": "lynx-keymap.toggleTerminalBottom"
      },{
        "key"    : "alt+w",
        "mac"    : "alt+w",
        "command": "workbench.action.quickOpenTerm"
      },{
        "key"    : "alt+q",
        "mac"    : "alt+q",
        "command": "workbench.action.focusFirstEditorGroup"
      },
      
      
      
      
      
      
      
      
      {
        "key"    : "alt+capslock",
        "mac"    : "alt+capslock",
        "command": "lynx-keymap.toggleTerminalLeftAndRight"
      },{
        "key"    : "ctrl+capslock",
        "mac"    : "cmd+capslock",
        "command": "lynx-keymap.openAndCloseAIChatAndTerminal"
      },{
        "key"    : "ctrl+tab",
        "mac"    : "cmd+tab",
        "command": "workbench.action.toggleSidebarVisibility"
      },
      
      
      
      
      
      
      
      
      {
        "key"    : "ctrl+alt+enter",
        "mac"    : "cmd+alt+return",
        "command": "git.push",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+enter",
        "mac"    : "alt+return",
        "command": "git.commit",
        "when"   : "scmProvider == git"
      },
      
      {
        "key"    : "alt+3",
        "mac"    : "alt+3",
        "command": "git.unstageAll",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+2",
        "mac"    : "alt+2",
        "command": "lynx-keymap.generateAICommit",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+1",
        "mac"    : "alt+1",
        "command": "git.stageAll",
        "when"   : "scmProvider == git"
      },


      {
        "key"    : "alt+c",
        "mac"    : "alt+c",
        "command": "explorer.newFolder"
      },{
        "key"    : "alt+x",
        "mac"    : "alt+x",
        "command": "explorer.newFile"
      },
      {
        "key"    : "alt+z",
        "mac"    : "alt+z",
        "command": "editor.action.toggleWordWrap"
      },
      
      {
        "key"    : "ctrl+3",
        "mac"    : "cmd+3",
        "command": "workbench.view.extensions"
      },{
        "key"    : "ctrl+2",
        "mac"    : "cmd+2",
        "command": "workbench.view.scm"
      },{
        "key"    : "ctrl+1",
        "mac"    : "cmd+1",
        "command": "workbench.view.explorer"
      }
    ],
    "commands": [
      {
        "command": "lynx-keymap.generateAICommit",
        "title"  : "Generate AI Commit Message"
      },

      {
        "command": "lynx-keymap.openAndCloseAIChat",
        "title"  : "Open and Close AI Chat"
      },{
        "command": "lynx-keymap.openAndCloseAIChatAndTerminal",
        "title"  : "Smart Close: AI Chat or Terminal"
      },{
        "command": "lynx-keymap.createNewAISession",
        "title"  : "Create New AI Session"
      },{
        "command": "lynx-keymap.showAIHistory",
        "title"  : "Show AI Chat History"
      },{
        "command": "lynx-keymap.selectModels",
        "title"  : "Select AI Model"
      },{
        "command": "lynx-keymap.toggleAgentMode",
        "title"  : "Toggle AI Agent Mode"
      },{
        "command": "lynx.toggleSuggestionAI",
        "title"  : "Toggle AI Suggestions"
      },{
        "command": "lynx-keymap.selectCode",
        "title"  : "AI Select Code"
      },

      {
        "command": "lynx-keymap.toggleTerminalLeftAndRight",
        "title"  : "Toggle Terminal Left and Right"
      },{
        "command": "lynx-keymap.toggleTerminalBottom",
        "title"  : "Toggle Terminal Bottom"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun esbuild.js",
    "watch": "bun esbuild.js --watch",
    "package": "bun esbuild.js --production",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.25.0"
  }
}
